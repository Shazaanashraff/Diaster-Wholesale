{
  "name": "diaster-wholesale",
  "private": true,
  "version": "0.1.64",
  "description": "Desktop wholesale operations app built with React, Vite, and Electron.",
  "author": "Diaster",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:sandbox": "concurrently -k \"npm:dev:sandbox-renderer\" \"npm:dev:electron\"",
    "dev:sandbox-renderer": "vite --mode sandbox",
    "start": "electron .",
    "build": "npm run build:renderer",
    "build:renderer": "tsc -b && vite build",
    "build:sandbox": "tsc -b && vite build --mode sandbox",
    "dist": "npm run build:renderer && electron-builder --publish never",
    "dist:win": "npm run build:renderer && electron-builder --win nsis --publish never",
    "dist:sandbox": "npm run build:sandbox && electron-builder --publish never",
    "dist:publish": "npm run build:renderer && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:egress": "supabase db query --linked --agent=no -f scripts/verify-egress-optimization.sql",
    "simulate:egress": "node scripts/simulate-egress.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sandbox:reset": "node scripts/sandbox-reset.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "dexie": "^4.4.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.7",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.4.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "postcss": "^8.4.49",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.0.7",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.1.1",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.diaster.wholesale",
    "productName": "Diaster Wholesale",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Shazaanashraff",
        "repo": "Diaster-Wholesale",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Diaster.Wholesale-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Diaster Wholesale",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/nsis-custom.nsh"
    }
  }
}
