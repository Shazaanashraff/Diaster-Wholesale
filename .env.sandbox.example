# Sandbox Environment Template
# Copy this to .env.sandbox and fill in your values.
# Use the SAME Supabase project as production — all queries will hit
# the 'sandbox' schema instead of 'public', so production data is safe.
#
# Steps:
#   1. Copy VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY from your .env file.
#   2. Run sandbox-setup.sql once in your Supabase SQL Editor to create the schema.
#   3. In Supabase Dashboard → Settings → API → add 'sandbox' to Exposed Schemas.
#   4. Run: npm run dev:sandbox

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_SUPABASE_SCHEMA=sandbox
VITE_APP_MODE=sandbox

# Direct Postgres connection string used by `npm run sandbox:reset`
# (scripts/sandbox-reset.mjs) and the sandbox-isolation test — the
# JS Supabase client can't run TRUNCATE, so this talks to Postgres
# directly. Find it under Supabase Dashboard → Settings → Database →
# Connection string (use the pooler URI in "Session" mode).
SANDBOX_DB_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_ID.supabase.co:5432/postgres
