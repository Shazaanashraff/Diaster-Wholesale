# Sandbox Environment Template
# Copy this to .env.sandbox and fill in your values.
# Use the SAME Supabase project as production — all queries will hit
# the 'sandbox' schema instead of 'public', so production data is safe.
#
# Steps:
#   1. Copy VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY from your .env file.
#   2. Apply supabase/migrations/20260626000000_sandbox_schema_and_meta.sql
#      (via `supabase db push` or the Supabase SQL Editor) to create the schema.
#   3. In Supabase Dashboard → Settings → API → add 'sandbox' to Exposed Schemas.
#   4. Run: npm run dev:sandbox
#   5. To wipe + reseed ONLY the sandbox schema (never touches production data
#      in `public`), set SANDBOX_DB_URL below and run: npm run sandbox:reset

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_SUPABASE_SCHEMA=sandbox
VITE_APP_MODE=sandbox

# Direct Postgres connection string (Supabase Dashboard → Settings → Database →
# Connection string → URI). Required only for `npm run sandbox:reset` and the
# sandbox isolation test — never used by the app itself.
SANDBOX_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
